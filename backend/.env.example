# ============================================================
# CRM Vittalis v2 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── EVOLUTION API (WhatsApp) ─────────────────────────────────
# Suba a Evolution API no Railway: https://railway.app
# Repositório: https://github.com/EvolutionAPI/evolution-api
# Após subir, crie uma instância chamada "vittalis" no painel

EVOLUTION_API_URL=https://sua-evolution-api.up.railway.app
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=vittalis

# Como configurar o webhook de retorno (mensagens recebidas):
# No painel da Evolution API → Instâncias → vittalis → Webhook
# URL: https://seu-crm.com/api/inbox/webhook/whatsapp
# Eventos: messages.upsert


# ── INSTAGRAM (Meta Graph API) ───────────────────────────────
# 1. Acesse: https://developers.facebook.com
# 2. Crie um app → Tipo: Business
# 3. Adicione produto "Instagram" → Mensagens
# 4. Gere um token de acesso de longa duração
# 5. Configure o webhook:
#    URL: https://seu-crm.com/api/inbox/webhook/instagram
#    Token: vittalis_webhook_2024 (ou mude o valor abaixo)

INSTAGRAM_ACCESS_TOKEN=seu_token_instagram_aqui
INSTAGRAM_VERIFY_TOKEN=vittalis_webhook_2024
INSTAGRAM_PAGE_ID=id_da_pagina_do_instagram


# ── ANTHROPIC (Resumo IA) ────────────────────────────────────
# Necessário para o botão "Resumo IA" nas conversas
# Obtenha em: https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-...


# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
